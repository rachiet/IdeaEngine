# ── .NET build output ─────────────────────────────────────────────
# Regenerated by `dotnet build`/`restore`; never source.
bin/
obj/
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
*.dll
*.pdb
*.exe

# Restore/build caches and generated project metadata
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets
*.nuget.dgspec.json
*.assemblyinfo.cs
*.assemblyinfoinputs.cache
*.cache

# Test/coverage artifacts
[Tt]est[Rr]esults/
*.trx
*.coverage
coverage*.json
coverage*.xml
coverage*.info

# ── IDE / editor ──────────────────────────────────────────────────
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.swp
*~

# ── OS cruft ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Secrets & runtime data (must never be committed) ──────────────
# Forge's own credentials live at ~/forge_env; the encrypted vault and all
# client project data live under FORGE_HOME (default ~/forge-data), both
# deliberately OUTSIDE this repo. These patterns are belt-and-braces in case
# someone points FORGE_HOME here or drops a stray env file in.
forge_env
*.env
.env
.env.*
forge-data/
vault/
*.key
key.bin
secrets.json
*.log
forge.log
